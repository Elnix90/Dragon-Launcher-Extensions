<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission Internet nécessaire pour vérifier GitHub -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- Permission pour Dragon Launcher -->
    <uses-permission android:name="org.dragon.launcher.APP_EXTENSION" />

    <application
        android:allowBackup="true"
        android:label="Dragon Auto-Update Extension"
        android:supportsRtl="true">

        <service
            android:name=".UpdateManagerService"
            android:enabled="true"
            android:exported="true"
            android:permission="org.dragon.launcher.APP_EXTENSION">
            <intent-filter>
                <action android:name="org.dragon.launcher.ACTION_CHECK_UPDATES" />
            </intent-filter>
        </service>

    </application>

</manifest>
