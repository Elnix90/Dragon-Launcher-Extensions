<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission Internet pour télécharger les polices -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- Permission pour Dragon Launcher -->
    <uses-permission android:name="org.elnix.dragonlauncher.APP_EXTENSION" />

    <application
        android:label="Dragon Fonts Extension"
        android:theme="@style/Theme.AppCompat.NoActionBar">

        <service
            android:name=".FontProviderService"
            android:permission="org.elnix.dragonlauncher.APP_EXTENSION"
            android:exported="true">
            <intent-filter>
                <action android:name="org.elnix.dragonlauncher.ACTION_GET_FONTS" />
            </intent-filter>
        </service>

        <activity
            android:name=".FontListActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.DayNight"
            android:label="Fonts Explorer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="org.elnix.dragonlauncher.ACTION_FONTS_SETTINGS" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

    </application>

</manifest>
