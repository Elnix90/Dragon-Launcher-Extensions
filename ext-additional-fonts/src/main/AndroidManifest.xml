<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission Internet pour télécharger les polices -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- Permission pour Dragon Launcher -->
    <uses-permission android:name="com.dragon.launcher.APP_EXTENSION" />

    <application
        android:label="Dragon Fonts Extension"
        android:theme="@style/Theme.AppCompat.NoActionBar">

        <service
            android:name=".FontProviderService"
            android:exported="true"
            android:permission="com.dragon.launcher.APP_EXTENSION">
            <intent-filter>
                <action android:name="com.dragon.launcher.ACTION_GET_FONTS" />
            </intent-filter>
        </service>

    </application>

</manifest>
